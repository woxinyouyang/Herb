<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme - edge-to-edge -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#8B1A1A</item>
        <item name="colorPrimaryDark">#3C2415</item>
        <item name="colorAccent">#D4A574</item>
        <item name="android:statusBarColor">#3C2415</item>
        <item name="android:navigationBarColor">#F5F0E8</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>